# Anthropic API key. Leave empty to reuse Claude Code's existing login.
ANTHROPIC_API_KEY=

# Default working directory Claude operates in. Forward slashes work on Windows.
DEFAULT_CWD=E:/Project

# Server bind address. Keep on 127.0.0.1 — Tailscale Serve reverse-proxies to it.
HOST=127.0.0.1
PORT=8000

# Friendly name shown in the phone app's source picker.
# Defaults to the OS hostname if not set.
BRIDGE_NAME=

# CORS origins allowed to talk to this bridge from a different host.
# Use "*" (default) for personal use over Tailscale — Tailscale is your auth.
# Or whitelist specific PWA origins, comma-separated:
#   ALLOWED_ORIGINS=https://home-pc.tail-xxx.ts.net,https://office-pc.tail-xxx.ts.net
ALLOWED_ORIGINS=*

# VAPID keys for Web Push. Generate once via:  vapid --gen
# (pip install py-vapid)
VAPID_EMAIL=you@example.com
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# Optional POI providers used by the check-in modal's nearby-POI search.
# Sources fire in parallel and merge by name + ~30m. All optional;
# without any key, only OpenStreetMap Overpass is used (sparse in some areas).
#
# Foursquare Places — best US/global commercial coverage. Get a Service API
# Key at https://foursquare.com/developers/ (Service Key, not OAuth client).
FOURSQUARE_KEY=
#
# 高德地图 Web API — China-only POI data. Apply at https://console.amap.com/
AMAP_KEY=
