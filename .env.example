# Anthropic API key. Leave empty to reuse Claude Code's existing login.
ANTHROPIC_API_KEY=

# Default working directory Claude operates in. Forward slashes work on Windows.
DEFAULT_CWD=E:/Project

# Server bind address. Keep on 127.0.0.1 — Tailscale Serve reverse-proxies to it.
HOST=127.0.0.1
PORT=8000

# VAPID keys for Web Push. Generate once via:  vapid --gen
# (pip install py-vapid)
VAPID_EMAIL=you@example.com
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
